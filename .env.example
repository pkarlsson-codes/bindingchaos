# Docker Compose environment configuration
#
# For local development: these defaults are baked into docker-compose.yml via ${VAR:-default}
# syntax, so you don't need this file at all unless you want to override them.
#
# For any real deployment: copy this file to .env and replace every value below.
# .env is gitignored and must never be committed.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RabbitMQ
RABBITMQ_USER=dev_user
RABBITMQ_PASSWORD=dev_password

# Keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Seq
SEQ_ADMIN_PASSWORD=admin
