{
  "name": "bindingchaos-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean:api": "node -e \"require('fs').rmSync('./src/api',{recursive:true,force:true})\"",
    "generate-api": "npm run clean:api && npx @openapitools/openapi-generator-cli generate -i http://localhost:4000/swagger/v1/swagger.json -g typescript-fetch -o ./src/api --additional-properties=supportsES6=true,withInterfaces=true,basePath=http://localhost:4000,nullSafeTypes=true,stringEnums=true",
    "generate-api-local": "npm run clean:api && npx @openapitools/openapi-generator-cli generate -i ./api-spec.json -g typescript-fetch -o ./src/api --additional-properties=supportsES6=true,withInterfaces=true,basePath=http://localhost:4000,nullSafeTypes=true,stringEnums=true",
    "generate-api-from-spec": "npm run clean:api && npx @openapitools/openapi-generator-cli generate -i ./api-spec.json -g typescript-fetch -o ./src/api --additional-properties=supportsES6=true,withInterfaces=true,basePath=http://localhost:4000,nullSafeTypes=true,stringEnums=true",
    "dead-code:list": "node scripts/dead-code-detector.js --list",
    "dead-code:remove": "node scripts/dead-code-detector.js --remove",
    "dead-code:advanced": "node scripts/advanced-dead-code-detector.js --list",
    "dead-code:clean": "npm run dead-code:remove && npm run lint"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.7",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
