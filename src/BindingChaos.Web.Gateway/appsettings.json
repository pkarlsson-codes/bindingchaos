{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "BindingChaos": "Information"
    }
  },
  "Authentication": {
    "OIDC": {
      "Authority": "",
      "ClientId": "gateway-bff",
      "ClientSecret": "",
      "Scope": "openid profile email",
      "RedirectUri": "",
      "PostLoginRedirect": "",
      "PostLogoutRedirect": ""
    },
    "TokenStore": {
      "DefaultTtlMinutes": 10080,
      "Redis": {
        "ConnectionString": ""
      }
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
    ]
  },
  "CorePlatform": {
    "BaseAddress": ""
  },
  "Gateway": {
    "BaseUrl": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "BindingChaos": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/web-gateway-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithThreadId"
    ]
  }
}
