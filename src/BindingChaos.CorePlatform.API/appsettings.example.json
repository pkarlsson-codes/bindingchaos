{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": "Host=localhost;Database=bindingchaos;Username=postgres;Password=postgres"
  },
  "InternalJwt": {
    "Issuer": "BindingChaos.Gateway",
    "Audience": "BindingChaos.CorePlatform",
    "SigningKey": "your-jwt-signing-key-here"
  },
  "Geolocation": {
    "IpifyApiKey": "your-ipify-api-key-here",
    "IpInfoApiKey": "your-ipinfo-api-key-here"
  },
  "Pseudonymity": {
    "HmacSecretKey": "your-pseudonymity-hmac-secret-key-here"
  }
}
