{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "BindingChaos": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
  },
  "Api": {
    "Title": "BindingChaos Core Platform API",
    "Version": "1.0.0",
    "Description": "Unified API surface for all core bounded contexts in the BindingChaos stigmergic coordination platform.",
    "EnableSwagger": true,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5173",
      "https://localhost:3000",
      "https://localhost:4200",
      "https://localhost:5173"
    ],
    "RateLimiting": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    },
    "Security": {
      "RequireAuthentication": false,
      "JwtIssuer": "BindingChaos",
      "JwtAudience": "BindingChaosAPI",
      "JwtSecretKey": "your-secret-key-here-change-in-production"
    }
  },
  "Pseudonymity": {
    "HmacSecretKey": "development-key-override-with-environment-variable-in-production"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "BindingChaos": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/bindingchaos-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithThreadId"
    ]
  },
  "Cors": {
    "AllowedOrigins": [
    ]
  },
  "Minio": {
    "Endpoint": "",
    "AccessKey": "",
    "SecretKey": "",
    "UseSsl": false
  }
}
