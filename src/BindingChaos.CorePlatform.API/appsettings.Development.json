{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "Marten": "Warning",
      "Npgsql": "Warning",
      "Weasel": "Warning",
      "JasperFx": "Warning",
      "BindingChaos": "Information"
    }
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Database=bindingchaos;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Api": {
    "EnableSwagger": true,
    "Security": {
      "RequireAuthentication": false
    }
  },
  "Pseudonymity": {
    "HmacSecretKey": "development-key-override-with-environment-variable-in-production"
  },
  "InternalJwt": {
    "Issuer": "BindingChaos.Gateway",
    "Audience": "BindingChaos.CorePlatform",
    "SigningKey": "dev-internal-jwt-secret-change-me"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Marten": "Warning",
        "Npgsql": "Warning",
        "Weasel": "Warning",
        "JasperFx": "Warning",
        "BindingChaos": "Information"
      }
    },
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/bindingchaos-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4000",
      "https://localhost:4001"
    ]
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "UseSsl": false
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "dev_user",
    "Password": "dev_password"
  },
  "Neo4j": {
    "Uri": "bolt://localhost:7687"
  }
}
